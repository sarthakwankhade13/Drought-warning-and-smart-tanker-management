PORT=5000
NODE_ENV=development

# Local MySQL Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=water_governance
DB_SSL=false

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# JWT Secret (Generate using: node generate-jwt-secret.js)
JWT_SECRET=your_secure_jwt_secret_key_here_minimum_32_characters

# WSI Weight Configuration (must sum to 1.0)
WSI_RAINFALL_WEIGHT=0.35
WSI_GROUNDWATER_WEIGHT=0.30
WSI_POPULATION_WEIGHT=0.20
WSI_STORAGE_WEIGHT=0.15

# Demand Calculation
DAILY_WATER_PER_CAPITA=55
HIGH_WSI_THRESHOLD=70
HIGH_WSI_ADJUSTMENT=1.20

# API Keys (Optional - Open-Meteo is free and requires no key)
OPENWEATHER_API_KEY=your_openweather_api_key_here
WEATHER_API_KEY=your_weatherapi_com_key_here
GOVERNMENT_API_KEY=
